# Backend environment for DTR Automation
# Fill these values from your Supabase project. KEEP .env FILE SECRET.
# Required for backend privileged operations: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY

# Supabase project URL (Project settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (Project settings → API → Service Role Key)
# REQUIRED for server-side operations (backups, admin queries).
# DO NOT commit or share this key in .env file.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-key-here

# Public / anon key (optional). This key is safe for client use.
SUPABASE_ANON_KEY=your-anon-key-here

# Comma-separated allowed emails for OTP authentication
SUPABASE_AUTH_ALLOWED_EMAILS=email1@example.com,email2@example.com

# Storage bucket used for backups
SUPABASE_BACKUP_BUCKET=your-backup-bucket-name

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# App timezone and backup cron
APP_TIMEZONE=UTC
DAILY_BACKUP_CRON=0 23 * * *

# Email configuration (Gmail SMTP for OTP delivery)
# Use Gmail app-specific password, not your account password
EMAIL_SENDER=your-gmail-email@gmail.com
EMAIL_APP_PASSWORD=your-app-specific-password
